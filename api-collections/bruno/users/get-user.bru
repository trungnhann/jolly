meta {
  name: Get User
  type: http
  seq: 3
}

get {
  url: {{baseUrl}}/users/{{user_uuid}}
  auth: bearer
}

auth:bearer {
  token: {{jwt_token}}
}

tests {
  test("status code is 200", () => {
    expect(res.status).to.equal(200);
  });

  test("returns user_uuid", () => {
    expect(res.body).to.have.property("user_uuid");
  });
}

